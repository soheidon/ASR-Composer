{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ASR Composer",
  "version": "0.1.0",
  "identifier": "com.asrcomposer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "resources": [
      "resources/google-stt-test-ja.wav",
      "resources/xiaomi-mimo-asr-test-en.wav",
      "resources/local-asr/base/Dockerfile",
      "resources/local-asr/common/constraints-reazonspeech.txt",
      "resources/local-asr/common/requirements-diar.txt",
      "resources/local-asr/common/diarize.py",
      "resources/local-asr/common/orchestrator.py",
      "resources/local-asr/common/output_writer.py",
      "resources/local-asr/common/smoke_test.py",
      "resources/local-asr/reazonspeech/Dockerfile",
      "resources/local-asr/reazonspeech/requirements-asr.txt",
      "resources/local-asr/reazonspeech/transcribe.py"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ASR Composer",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "decorations": false,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
